@model BTITPORequest.Models.POCreateViewModel
@{
    ViewData["Title"] = "New PO Request";
    ViewData["BreadcrumbItems"] = new List<(string, string?)>
    {
        ("Dashboard", "/"),
        ("PO Requests", "/PORequest"),
        ("New PO", null)
    };
    bool isEdit = Model.PO.POId > 0;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">@(isEdit ? $"Edit PO — {Model.PO.PONumber}" : "New PO Request")</h4>
        <p class="text-muted mb-0" style="font-size:.85rem;">Fill in the purchase order details below</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<form id="poForm" asp-action="@(isEdit ? "Edit" : "Create")" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit)
    {
        <input type="hidden" asp-for="PO.POId" />
    }
    <input type="hidden" id="lineItemsJson" name="lineItemsJson" />
    @* DeptPrefix hidden — ค่าเปลี่ยนโดย radio button ด้านล่าง *@
    <input type="hidden" id="deptPrefixInput" name="deptPrefix" value="@Model.DeptPrefix" />
    @* SourcePRIds — PRs ที่ใช้สร้าง PO นี้ (สำหรับ Link PR→PO) *@
    @foreach (var prId in Model.SourcePRIds)
    {
        <input type="hidden" name="sourcePRIds" value="@prId" />
    }

    <div class="row g-3">
        <!-- Left column: Vendor & Header -->
        <div class="col-lg-8">

            <!-- PO Header -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent border-0 pb-0">
                    <h6 class="fw-semibold mb-0"><i class="bi bi-file-earmark me-2 text-primary"></i>PO Header</h6>
                </div>
                <div class="card-body">
                    @if (!isEdit)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-tag me-1 text-primary"></i>Department / PO Series
                            </label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input dept-radio" type="radio" name="_deptRadio"
                                           id="deptIT" value="IT" @(Model.DeptPrefix == "IT" ? "checked" : "") />
                                    <label class="form-check-label fw-semibold" for="deptIT">
                                        <span class="badge bg-primary me-1">IT</span> IT Inventory
                                        <small class="text-muted">(IT-YY-NNNNN)</small>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input dept-radio" type="radio" name="_deptRadio"
                                           id="deptOS" value="OS" @(Model.DeptPrefix == "OS" ? "checked" : "") />
                                    <label class="form-check-label fw-semibold" for="deptOS">
                                        <span class="badge bg-success me-1">OS</span> Office Stationery
                                        <small class="text-muted">(OS-YY-NNNNN)</small>
                                    </label>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
                            <input type="date" asp-for="PO.PODate" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Internal Ref. A/C</label>
                            <input type="text" asp-for="PO.InternalRefAC" class="form-control" placeholder="e.g. 438700/310" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Credit No.</label>
                            <input type="text" asp-for="PO.CreditNo" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Ref. No.</label>
                            <input type="text" asp-for="PO.RefNo" class="form-control" placeholder="e.g. CPS1095/67" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Subject <span class="text-danger">*</span></label>
                            <input type="text" asp-for="PO.Subject" class="form-control"
                                   placeholder="please supply the following goods / services to us:" required />
                        </div>

                        @* ── Reference fields (optional, backward-compat) ── *@
                        <div class="col-12">
                            <hr class="my-1" />
                            <p class="text-muted mb-2" style="font-size:.8rem;">
                                <i class="bi bi-info-circle me-1"></i>
                                Reference fields (optional) — สำหรับอ้างอิงกับระบบเดิม
                            </p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Ref. Old PO No.</label>
                            <input type="text" asp-for="PO.OldPONumber" class="form-control"
                                   placeholder="เลข PO เดิม" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Internal Contact</label>
                            <input type="text" asp-for="PO.InternalContact" class="form-control"
                                   placeholder="ผู้ติดต่อภายใน" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Work Order No.</label>
                            <input type="text" asp-for="PO.WorkOrderNo" class="form-control"
                                   placeholder="WO No." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">NCR No.</label>
                            <input type="text" asp-for="PO.NCRNo" class="form-control"
                                   placeholder="NCR No." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">IR/CR No.</label>
                            <input type="text" asp-for="PO.IRCRNo" class="form-control"
                                   placeholder="IR/CR No." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Change No.</label>
                            <input type="text" asp-for="PO.ChangeNo" class="form-control"
                                   placeholder="Change No." />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Vendor Info -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent border-0 pb-0 d-flex align-items-center justify-content-between">
                    <h6 class="fw-semibold mb-0"><i class="bi bi-building me-2 text-primary"></i>Vendor / Supplier</h6>
                </div>
                <div class="card-body">
                    <!-- Vendor Search -->
                    <div class="mb-3 position-relative">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-search me-1 text-muted"></i>ค้นหา Vendor จากรายการ
                        </label>
                        <input type="text" id="vendorSearch" class="form-control"
                               placeholder="พิมพ์ชื่อบริษัทหรือผู้ติดต่อ..." autocomplete="off" />
                        <div id="vendorDropdown"
                             class="position-absolute w-100 bg-white border rounded shadow-sm"
                             style="z-index:1000;max-height:220px;overflow-y:auto;display:none;">
                        </div>
                        <div class="form-text text-muted">เลือกจากรายการหรือพิมพ์ข้อมูลใหม่ได้เลย</div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Attn (Contact Person) <span class="text-danger">*</span></label>
                            <input type="text" asp-for="PO.VendorAttn" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Company Name <span class="text-danger">*</span></label>
                            <input type="text" asp-for="PO.VendorCompany" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Address <span class="text-danger">*</span></label>
                            <textarea asp-for="PO.VendorAddress" class="form-control" rows="2" required></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Tel No.</label>
                            <input type="text" asp-for="PO.VendorTel" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Fax No.</label>
                            <input type="text" asp-for="PO.VendorFax" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">E-mail</label>
                            <input type="email" asp-for="PO.VendorEmail" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Line Items -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-semibold mb-0"><i class="bi bi-list-ul me-2 text-primary"></i>Line Items</h6>
                    <button type="button" class="btn btn-sm btn-primary" id="addLineBtn">
                        <i class="bi bi-plus me-1"></i>Add Item
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0" id="lineTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:40px;">#</th>
                                    <th>Description</th>
                                    <th style="width:110px;">Quantity</th>
                                    <th style="width:130px;">Unit Price</th>
                                    <th style="width:130px;">Amount</th>
                                    <th style="width:40px;"></th>
                                </tr>
                            </thead>
                            <tbody id="lineBody">
                                <!-- Rows injected by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right column: Totals & Notes & Actions -->
        <div class="col-lg-4">

            <!-- VAT & Totals -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent border-0 pb-0">
                    <h6 class="fw-semibold mb-0"><i class="bi bi-calculator me-2 text-primary"></i>Totals</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">VAT %</label>
                        <select asp-for="PO.VatPercent" class="form-select" id="vatSelect">
                            <option value="0">0% (Exempt)</option>
                            <option value="7">7%</option>
                        </select>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Subtotal</span>
                        <span class="fw-semibold" id="displayTotal">0.00</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">VAT</span>
                        <span class="fw-semibold" id="displayVat">0.00</span>
                    </div>
                    <div class="d-flex justify-content-between pt-2 border-top">
                        <span class="fw-bold">Grand Total</span>
                        <span class="fw-bold fs-5 text-primary" id="displayGrand">0.00</span>
                    </div>
                    <div class="mt-2 text-muted" style="font-size:.75rem;" id="amountWords"></div>

                    <!-- Hidden fields for form submission -->
                    <input type="hidden" asp-for="PO.Total" id="hiddenTotal" />
                    <input type="hidden" asp-for="PO.VatAmount" id="hiddenVat" />
                    <input type="hidden" asp-for="PO.GrandTotal" id="hiddenGrand" />
                    <input type="hidden" asp-for="PO.GrandTotalText" id="hiddenGrandText" />
                </div>
            </div>

            <!-- Workflow Assignment -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent border-0 pb-0">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-diagram-3 me-2 text-primary"></i>Assign Workflow
                    </h6>
                    <p class="text-muted mb-0" style="font-size:.75rem;">
                        กำหนดผู้ที่จะลงนามในแต่ละขั้นตอน
                    </p>
                </div>
                <div class="card-body">
                    @{
                        // Build JS data array จาก HR employees
                        var empJson = Newtonsoft.Json.JsonConvert.SerializeObject(
                            Model.Issuers.Select(u => new {
                                sam  = u.samacc,
                                name = u.fName
                            }));
                    }
                    <script>
                        var _hrEmployees = @Html.Raw(empJson);
                    </script>

                    <!-- Issued by -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <span class="badge bg-info me-1">Issued</span>
                            ผู้ Issue PO <span class="text-danger">*</span>
                        </label>
                        <input type="hidden" id="selectedIssuerSam" name="selectedIssuerSam"
                               value="@Model.SelectedIssuerSam" required>
                        <input type="text" id="issuerSearch" class="form-control" autocomplete="off"
                               placeholder="พิมพ์ชื่อเพื่อค้นหา..." style="font-size:.85rem;">
                        <div id="issuerDropdown" class="list-group position-absolute z-3 w-100 shadow-sm d-none"
                             style="max-height:200px;overflow-y:auto;"></div>
                        <div id="issuerDisplay" class="mt-1 small text-success fw-semibold"></div>
                    </div>

                    <!-- Authorized by -->
                    <div class="mb-0">
                        <label class="form-label fw-semibold">
                            <span class="badge bg-success me-1">Authorized</span>
                            ผู้อนุมัติ <span class="text-danger">*</span>
                        </label>
                        <input type="hidden" id="selectedApprover1Sam" name="selectedApprover1Sam"
                               value="@Model.SelectedApprover1Sam" required>
                        <input type="text" id="approverSearch" class="form-control" autocomplete="off"
                               placeholder="พิมพ์ชื่อเพื่อค้นหา..." style="font-size:.85rem;">
                        <div id="approverDropdown" class="list-group position-absolute z-3 w-100 shadow-sm d-none"
                             style="max-height:200px;overflow-y:auto;"></div>
                        <div id="approverDisplay" class="mt-1 small text-success fw-semibold"></div>
                        <input type="hidden" name="selectedApprover2Sam" value="">
                    </div>
                </div>
            </div>

            <!-- Notes -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent border-0 pb-0">
                    <h6 class="fw-semibold mb-0"><i class="bi bi-sticky me-2 text-primary"></i>Notes</h6>
                </div>
                <div class="card-body">
                    <textarea asp-for="PO.Notes" class="form-control" rows="5" style="font-size:.8rem;"></textarea>
                </div>
            </div>

            <!-- Actions -->
            <div class="card border-0 shadow-sm">
                <div class="card-body d-grid gap-2">
                    <button type="submit" name="submitNow" value="false" class="btn btn-outline-secondary">
                        <i class="bi bi-floppy me-2"></i>Save as Draft
                    </button>
                    <button type="submit" name="submitNow" value="true" class="btn btn-primary"
                            id="submitAndSignBtn">
                        @if (Model.PO.Status == BTITPORequest.Models.POStatus.UnderRevision)
                        {
                            <i class="bi bi-arrow-repeat me-2"></i><text>Re-Submit &amp; Sign</text>
                        }
                        else
                        {
                            <i class="bi bi-send me-2"></i><text>Submit &amp; Sign</text>
                        }
                    </button>
                    @if (isEdit)
                    {
                        <a href="/PORequest/Detail/@Model.PO.POId" class="btn btn-outline-danger">
                            <i class="bi bi-x-circle me-2"></i>ยกเลิก (ไม่บันทึก)
                        </a>
                    }
                </div>
            </div>

            @* Attachment panel — แสดงเฉพาะ Draft PO ที่มี POId แล้ว *@
            @if (Model.PO.POId > 0 && Model.PO.Status == BTITPORequest.Models.POStatus.Draft)
            {
                <partial name="_AttachmentPanel" model="Model.PO.POId" />
            }
            else if (Model.PO.POId == 0)
            {
                <div class="card border-0 shadow-sm mt-3">
                    <div class="card-body text-center text-muted py-3" style="font-size:.82rem;">
                        <i class="bi bi-paperclip me-1"></i>
                        บันทึก Draft ก่อน เพื่อแนบไฟล์
                    </div>
                </div>
            }
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/js/po-form.js" asp-append-version="true"></script>
    <script src="~/js/vendor-autocomplete.js" asp-append-version="true"></script>
    <script>
        var initialItems = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
            Model.LineItems,
            new Newtonsoft.Json.JsonSerializerSettings {
                ContractResolver = new Newtonsoft.Json.Serialization.CamelCasePropertyNamesContractResolver()
            }));
        initPOForm(initialItems);

        // ── Dept prefix radio → hidden input ─────────────────
        document.querySelectorAll('.dept-radio').forEach(function(r) {
            r.addEventListener('change', function() {
                document.getElementById('deptPrefixInput').value = this.value;
            });
        });

        // ── Person Search (Issued / Authorized) ──────────────
        function initPersonSearch(searchId, dropdownId, hiddenId, displayId, initSam) {
            var $search   = document.getElementById(searchId);
            var $dropdown = document.getElementById(dropdownId);
            var $hidden   = document.getElementById(hiddenId);
            var $display  = document.getElementById(displayId);

            function setSelected(sam, name) {
                $hidden.value  = sam;
                $search.value  = name;
                $display.innerHTML = sam ? '<i class="bi bi-check-circle-fill me-1"></i>' + name + ' (' + sam + ')' : '';
                $dropdown.classList.add('d-none');
                $dropdown.innerHTML = '';
            }

            // init จาก pre-selected value
            if (initSam) {
                var found = _hrEmployees.find(function(e) { return e.sam === initSam; });
                if (found) setSelected(found.sam, found.name);
            }

            $search.addEventListener('input', function() {
                var q = this.value.trim().toLowerCase();
                $hidden.value = '';
                $display.innerHTML = '';
                if (q.length < 1) { $dropdown.classList.add('d-none'); return; }
                var matches = _hrEmployees.filter(function(e) {
                    return e.name.toLowerCase().includes(q) || e.sam.toLowerCase().includes(q);
                }).slice(0, 20);
                if (!matches.length) { $dropdown.classList.add('d-none'); return; }
                $dropdown.innerHTML = matches.map(function(e) {
                    return '<button type="button" class="list-group-item list-group-item-action py-1 px-2" style="font-size:.82rem;" ' +
                           'data-sam="' + e.sam + '" data-name="' + e.name + '">' +
                           '<span class="fw-semibold">' + e.name + '</span> ' +
                           '<span class="text-muted">(' + e.sam + ')</span></button>';
                }).join('');
                $dropdown.classList.remove('d-none');
            });

            $dropdown.addEventListener('click', function(ev) {
                var btn = ev.target.closest('button[data-sam]');
                if (btn) setSelected(btn.dataset.sam, btn.dataset.name);
            });

            document.addEventListener('click', function(ev) {
                if (!$search.contains(ev.target) && !$dropdown.contains(ev.target))
                    $dropdown.classList.add('d-none');
            });
        }

        initPersonSearch('issuerSearch',   'issuerDropdown',   'selectedIssuerSam',    'issuerDisplay',   '@Model.SelectedIssuerSam');
        initPersonSearch('approverSearch', 'approverDropdown', 'selectedApprover1Sam', 'approverDisplay', '@Model.SelectedApprover1Sam');
    </script>
}
