@model BTITPORequest.Models.POApproveViewModel
@{
    ViewData["Title"] = $"Approve PO — {Model.PO.PONumber}";
    ViewData["BreadcrumbItems"] = new List<(string, string?)>
    {
        ("Dashboard", "/"),
        ("PO Requests", "/PORequest"),
        (Model.PO.PONumber, $"/PORequest/Detail/{Model.PO.POId}"),
        ($"Approve Level {Model.ApprovalLevel}", null)
    };
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-shield-check me-2 text-success"></i>
                    Approval — Level @Model.ApprovalLevel
                </h5>
                <p class="text-muted mb-0 mt-1" style="font-size:.85rem;">
                    PO: <strong>@Model.PO.PONumber</strong> &bull;
                    @Model.PO.VendorCompany &bull;
                    Grand Total: <strong>@Model.PO.GrandTotal.ToString("N2") Baht</strong>
                </p>
            </div>
            <div class="card-body">
                <!-- Summary -->
                <div class="alert alert-light border mb-4">
                    <div class="row g-2">
                        <div class="col-sm-6">
                            <div class="small text-muted">Company</div>
                            <div class="fw-semibold">@Model.PO.VendorCompany</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="small text-muted">Subject</div>
                            <div class="fw-semibold">@Model.PO.Subject</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="small text-muted">Grand Total</div>
                            <div class="fw-bold text-primary fs-5">@Model.PO.GrandTotal.ToString("N2")</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="small text-muted">Current Status</div>
                            <span class="badge bg-@Model.PO.StatusBadgeClass">@Model.PO.StatusLabel</span>
                        </div>
                    </div>
                </div>

                <form asp-action="Approve" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.PO.POId" />
                    <input type="hidden" name="level" value="@Model.ApprovalLevel" />
                    <input type="hidden" name="action" id="approvalAction" value="approve" />

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Remark (optional)</label>
                        <textarea name="remark" class="form-control" rows="3"
                                  placeholder="Add a note for this approval / rejection..."></textarea>
                    </div>

                    <div class="alert alert-info d-flex gap-2" style="font-size:.85rem;">
                        <i class="bi bi-info-circle-fill mt-1"></i>
                        <div>
                            Clicking <strong>Approve</strong> will call the BERNINA Digital Sign API to record your
                            electronic signature. The PO will advance to the next workflow step automatically.
                        </div>
                    </div>

                    <div class="d-flex gap-3 justify-content-end">
                        <a asp-action="Detail" asp-route-id="@Model.PO.POId" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-danger"
                                onclick="document.getElementById('approvalAction').value='reject'">
                            <i class="bi bi-x-circle me-2"></i>Reject
                        </button>
                        <button type="submit" class="btn btn-success"
                                onclick="document.getElementById('approvalAction').value='approve'">
                            <i class="bi bi-check-circle me-2"></i>
                            @(Model.ApprovalLevel == 2 ? "Final Approve" : "Approve")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
