@model BTITPORequest.Models.PORequestModel
@{
    ViewData["Title"] = $"PO {Model.PONumber}";
    ViewData["BreadcrumbItems"] = new List<(string, string?)>
    {
        ("Dashboard", "/"),
        ("PO Requests", "/PORequest"),
        (Model.PONumber, null)
    };
    string userSam = User.FindFirst("samacc")?.Value ?? "";

    // Helper: true ถ้ามีการลงนามแล้ว (ไม่ว่าจะเป็น crypto signature หรือ image)
    bool HasSigned(string sigBase64, string sigImage)
        => !string.IsNullOrEmpty(sigBase64) || !string.IsNullOrEmpty(sigImage);
}

<!-- Top Bar -->
<div class="d-flex flex-wrap align-items-start justify-content-between mb-4 gap-2">
    <div>
        <div class="d-flex align-items-center gap-2">
            <h4 class="fw-bold mb-0">@Model.PONumber</h4>
            <span class="badge bg-@Model.StatusBadgeClass fs-6">@Model.StatusLabel</span>
        </div>
        <p class="text-muted mb-0" style="font-size:.85rem;">
            Created by @Model.RequesterName &bull; @Model.CreatedAt.ToString("dd MMM yyyy HH:mm")
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        @if (Model.CanEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.POId" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
        @if (Model.CanDownloadPDF)
        {
            <a asp-action="DownloadPdf" asp-route-id="@Model.POId" class="btn btn-success btn-sm">
                <i class="bi bi-file-earmark-pdf me-1"></i>Download PDF
            </a>
        }
    </div>
</div>

<div class="row g-3">
    <!-- Left: PO Document Preview -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">

                <!-- Header -->
                <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
                    <div>
                        <div class="text-muted" style="font-size:.75rem;">TradeRegister No. 556201342</div>
                        <div class="text-muted" style="font-size:.75rem;">Input Value Added Tax No. 0515533000050</div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold text-primary" style="font-size:1.1rem;">made to create BERNINA</div>
                    </div>
                </div>

                <!-- PO Number + Date -->
                <div class="d-flex justify-content-between mb-3">
                    <div>
                        <div class="fw-bold" style="font-size:1rem;">PURCHASE ORDER No.</div>
                        <div class="fw-bold text-primary fs-5">@Model.PONumber</div>
                    </div>
                    <div class="text-end" style="font-size:.85rem;">
                        <div><span class="text-muted">Date:</span> @Model.PODate.ToString("M/d/yyyy")</div>
                        <div><span class="text-muted">For BT. Internal Ref. A/C:</span> @Model.InternalRefAC</div>
                        @if (!string.IsNullOrEmpty(Model.CreditNo))
                        {
                            <div><span class="text-muted">Credit No:</span> @Model.CreditNo</div>
                        }
                    </div>
                </div>

                <!-- Vendor Info -->
                <table class="table table-borderless mb-2" style="font-size:.85rem;">
                    <tr><td class="fw-semibold py-1" style="width:100px;">Attn:</td><td>@Model.VendorAttn</td></tr>
                    <tr><td class="fw-semibold py-1">Company:</td><td>@Model.VendorCompany</td></tr>
                    <tr><td class="fw-semibold py-1">Address:</td><td>@Model.VendorAddress</td></tr>
                    <tr>
                        <td class="fw-semibold py-1">Tel No.:</td>
                        <td>@Model.VendorTel</td>
                        <td class="fw-semibold py-1">Fax No.:</td>
                        <td>@Model.VendorFax</td>
                    </tr>
                    <tr><td class="fw-semibold py-1">E-mail:</td><td>@Model.VendorEmail</td></tr>
                    <tr><td class="fw-semibold py-1">Ref.:</td><td>@Model.RefNo</td></tr>
                    <tr>
                        <td class="fw-semibold py-1">Subject:</td>
                        <td colspan="3">@Model.Subject</td>
                    </tr>
                </table>

                <!-- Line Items -->
                <div class="table-responsive mb-3">
                    <table class="table table-bordered table-sm" style="font-size:.85rem;">
                        <thead class="bt-table-header">
                            <tr>
                                <th>#</th>
                                <th>Description</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Amount/Baht</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.LineItems)
                            {
                                <tr>
                                    <td>@item.LineNo</td>
                                    <td>@item.Description</td>
                                    <td class="text-center">@item.Quantity.ToString("N3")</td>
                                    <td class="text-end">@item.UnitPrice.ToString("N2")</td>
                                    <td class="text-end fw-semibold">@item.Amount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-end fw-semibold">Total</td>
                                <td class="text-end">@Model.Total.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td colspan="4" class="text-end fw-semibold">Vat @Model.VatPercent.ToString("0")%</td>
                                <td class="text-end">@Model.VatAmount.ToString("N2")</td>
                            </tr>
                            <tr class="table-active">
                                <td colspan="4" class="text-end fw-bold">Grand total</td>
                                <td class="text-end fw-bold text-primary">@Model.GrandTotal.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="text-center text-muted fst-italic mb-3" style="font-size:.85rem;">
                    ( @Model.GrandTotalText )
                </div>

                <!-- Notes -->
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="border rounded p-2 bg-light mb-3" style="font-size:.8rem;">
                        <strong>NOTES:</strong>
                        @foreach (var line in Model.Notes.Split('\n'))
                        {
                            <div>@line</div>
                        }
                    </div>
                }

                <!-- ── Signature Row ──────────────────────────────── -->
                @{
                    // Helper: render signature box ด้วย lazy-fetch fallback
                    // ถ้าไม่มีรูปใน DB → fetch ผ่าน /api/signature/image/{sam}
                    string SigBoxId(string role) => "sig-" + role.ToLower().Replace(" ", "-");
                }

                <div class="row text-center g-2 mt-2">

                    @* Supplier *@
                    <div class="col-3">
                        <div class="border rounded p-2 bg-light" style="min-height:90px;">
                            <div class="small fw-semibold text-muted mb-2">For Supplier<br />Sign &amp; Feedback</div>
                            <div style="height:38px;border:1px dashed #ccc;border-radius:4px;"></div>
                        </div>
                    </div>

                    @* Requested *@
                    @{
                        bool reqSigned = HasSigned(Model.RequesterSignatureBase64, Model.RequesterSignatureImage);
                        string reqSam = Model.RequesterSam;
                        bool reqHasStatus = Model.Status != POStatus.Draft;
                    }
                    <div class="col-3">
                        <div id="box-req" class="border rounded p-2 @(reqSigned ? "border-success border-2" : "")" style="min-height:90px;">
                            <div class="small fw-semibold text-muted mb-1">Requested:</div>

                            @if (!string.IsNullOrEmpty(Model.RequesterSignatureImage))
                            {
                                <!-- มีรูปใน DB แสดงทันที -->
                                <img src="data:image/png;base64,@Model.RequesterSignatureImage"
                                     alt="Signature" style="max-height:42px;max-width:100%;object-fit:contain;" class="mb-1" />
                            }
                            else if (reqHasStatus && !string.IsNullOrEmpty(reqSam))
                            {
                                <!-- ไม่มีรูปใน DB แต่มี samAcc → lazy fetch ผ่าน proxy -->
                                <div id="sig-img-req" class="sig-lazy" data-sam="@reqSam"
                                     style="min-height:42px;display:flex;align-items:center;justify-content:center;">
                                    <span class="text-muted" style="font-size:.7rem;">
                                        <i class="bi bi-arrow-repeat spin me-1"></i>loading...
                                    </span>
                                </div>
                            }
                            else
                            {
                                <div style="height:42px;"></div>
                            }

                            <div class="small fw-semibold">@Model.RequesterName</div>
                            <div class="text-muted" style="font-size:.7rem;">@Model.RequesterTitle</div>
                            @if (Model.RequestedDate.HasValue)
                            {
                                <div class="text-muted" style="font-size:.65rem;">
                                    @Model.RequestedDate.Value.ToString("dd/MM/yy HH:mm")
                                </div>
                            }
                        </div>
                    </div>

                    @* Issued *@
                    @{
                        bool issSigned = HasSigned(Model.IssuerSignatureBase64, Model.IssuerSignatureImage);
                        string issSam = Model.IssuerSam;
                    }
                    <div class="col-3">
                        <div id="box-iss" class="border rounded p-2 @(issSigned ? "border-success border-2" : "")" style="min-height:90px;">
                            <div class="small fw-semibold text-muted mb-1">Issued:</div>

                            @if (!string.IsNullOrEmpty(Model.IssuerSignatureImage))
                            {
                                <img src="data:image/png;base64,@Model.IssuerSignatureImage"
                                     alt="Signature" style="max-height:42px;max-width:100%;object-fit:contain;" class="mb-1" />
                            }
                            else if (!string.IsNullOrEmpty(issSam))
                            {
                                <div id="sig-img-iss" class="sig-lazy" data-sam="@issSam"
                                     style="min-height:42px;display:flex;align-items:center;justify-content:center;">
                                    <span class="text-muted" style="font-size:.7rem;">
                                        <i class="bi bi-arrow-repeat spin me-1"></i>loading...
                                    </span>
                                </div>
                            }
                            else if (issSigned)
                            {
                                <div class="text-success small mb-1">
                                    <i class="bi bi-patch-check-fill"></i> Digitally Signed
                                </div>
                            }
                            else
                            {

                                <div style="height:42px;"></div>
                            }

                            <div class="small fw-semibold">@Model.IssuerName</div>
                            <div class="text-muted" style="font-size:.7rem;">@Model.IssuerTitle</div>
                            @if (Model.IssuedDate.HasValue)
                            {
                                <div class="text-muted" style="font-size:.65rem;">
                                    @Model.IssuedDate.Value.ToString("dd/MM/yy HH:mm")
                                </div>
                            }
                        </div>
                    </div>

                    @* Authorized *@
                    @{
                        var authName = !string.IsNullOrEmpty(Model.Approver2Name) ? Model.Approver2Name : Model.Approver1Name ?? "";
                        var authTitle = !string.IsNullOrEmpty(Model.Approver2Title) ? Model.Approver2Title : Model.Approver1Title ?? "";
                        var authImg = !string.IsNullOrEmpty(Model.Approver2SignatureImage) ? Model.Approver2SignatureImage : Model.Approver1SignatureImage ?? "";
                        var authSig = !string.IsNullOrEmpty(Model.Approver2SignatureBase64) ? Model.Approver2SignatureBase64 : Model.Approver1SignatureBase64 ?? "";
                        var authSam = !string.IsNullOrEmpty(Model.Approver2Sam) ? Model.Approver2Sam : Model.Approver1Sam ?? "";
                        var authDate = Model.Approver2Date ?? Model.Approver1Date;
                        bool authSigned = HasSigned(authSig, authImg);
                    }
                    <div class="col-3">
                        <div id="box-auth" class="border rounded p-2 @(authSigned ? "border-success border-2" : "")" style="min-height:90px;">
                            <div class="small fw-semibold text-muted mb-1">Authorized:</div>

                            @if (!string.IsNullOrEmpty(authImg))
                            {
                                <img src="data:image/png;base64,@authImg"
                                     alt="Signature" style="max-height:42px;max-width:100%;object-fit:contain;" class="mb-1" />
                            }
                            else if (!string.IsNullOrEmpty(authSam))
                            {
                                <div id="sig-img-auth" class="sig-lazy" data-sam="@authSam"
                                     style="min-height:42px;display:flex;align-items:center;justify-content:center;">
                                    <span class="text-muted" style="font-size:.7rem;">
                                        <i class="bi bi-arrow-repeat spin me-1"></i>loading...
                                    </span>
                                </div>
                            }
                            else if (authSigned)
                            {
                                <div class="text-success small mb-1">
                                    <i class="bi bi-patch-check-fill"></i> Digitally Signed
                                </div>
                            }
                            else
                            {

                                <div style="height:42px;"></div>
                            }

                            <div class="small fw-semibold">@authName</div>
                            <div class="text-muted" style="font-size:.7rem;">@authTitle</div>
                            @if (authDate.HasValue)
                            {
                                <div class="text-muted" style="font-size:.65rem;">
                                    @authDate.Value.ToString("dd/MM/yy HH:mm")
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Right: Workflow & Actions -->
    <div class="col-lg-4">

        <!-- Action Panel -->
        @if (Model.CanSubmit || Model.CanIssue || Model.CanApprove1 || Model.CanApprove2)
        {
            <div class="card border-0 shadow-sm border-start border-primary border-4 mb-3">
                <div class="card-header bg-transparent border-0">
                    <h6 class="fw-semibold mb-0 text-primary">
                        <i class="bi bi-lightning-charge me-2"></i>Action Required
                    </h6>
                </div>
                <div class="card-body d-grid gap-2">
                    @if (Model.CanSubmit)
                    {
                        <form asp-action="Submit" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.POId" />
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-send me-2"></i>Submit &amp; Sign as Requester
                            </button>
                        </form>
                    }
                    @if (Model.CanIssue)
                    {
                        <form asp-action="Issue" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.POId" />
                            <button type="submit" class="btn btn-info w-100">
                                <i class="bi bi-pen me-2"></i>Issue &amp; Sign
                            </button>
                        </form>
                    }
                    @if (Model.CanApprove1)
                    {
                        <a asp-action="Approve" asp-route-id="@Model.POId" asp-route-level="1"
                           class="btn btn-success w-100">
                            <i class="bi bi-check-circle me-2"></i>Approve (Level 1)
                        </a>
                    }
                    @if (Model.CanApprove2)
                    {
                        <a asp-action="Approve" asp-route-id="@Model.POId" asp-route-level="2"
                           class="btn btn-success w-100">
                            <i class="bi bi-check-circle-fill me-2"></i>Final Approve (Level 2)
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Workflow Stepper -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent border-0 pb-0">
                <h6 class="fw-semibold mb-0">
                    <i class="bi bi-diagram-3 me-2 text-primary"></i>Approval Flow
                </h6>
            </div>
            <div class="card-body">
                @{
                    var steps = new[]
                    {
                                ("Draft",      POStatus.Draft,      "bi-pencil-square", "secondary"),
                                ("Requested",  POStatus.Requested,  "bi-person-check",  "primary"),
                                ("Issued",     POStatus.Issued,     "bi-send-check",    "info"),
                                ("Authorized", POStatus.Authorized, "bi-shield-check",  "warning"),
                                ("Completed",  POStatus.Completed,  "bi-trophy",        "success"),
                                };
                }
                <div class="bt-workflow">
                    @foreach (var (label, status, icon, color) in steps)
                    {
                        bool isDone = (int)Model.Status > (int)status || Model.Status == status;
                        bool isCurrent = Model.Status == status;

                        // แสดงชื่อผู้รับผิดชอบที่ pre-assign ไว้
                        string assignedPerson = status switch
                        {
                            POStatus.Issued => Model.IssuerName ?? Model.PreAssignedIssuerSam,
                            POStatus.Authorized => Model.Approver1Name ?? Model.PreAssignedApprover1Sam,
                            POStatus.Completed => Model.Approver2Name ?? Model.PreAssignedApprover2Sam,
                            _ => ""
                        };

                        <div class="bt-workflow-step @(isDone ? "done" : "") @(isCurrent ? "current" : "")">
                            <div class="bt-workflow-icon text-@color">
                                <i class="bi @icon"></i>
                            </div>
                            <div>
                                <div class="bt-workflow-label">@label</div>
                                @if (!string.IsNullOrEmpty(assignedPerson) && !isDone)
                                {
                                    <div class="text-muted" style="font-size:.7rem;">@assignedPerson</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Approval History -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pb-0">
                <h6 class="fw-semibold mb-0">
                    <i class="bi bi-clock-history me-2 text-primary"></i>History
                </h6>
            </div>
            <div class="card-body p-0">
                @if (!Model.ApprovalHistory.Any())
                {
                    <p class="text-muted p-3 mb-0" style="font-size:.85rem;">No history yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var h in Model.ApprovalHistory.OrderByDescending(x => x.ActionDate))
                        {
                            <li class="list-group-item px-3 py-2">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-semibold" style="font-size:.85rem;">@h.Action</span>
                                    <span class="text-muted" style="font-size:.75rem;">
                                        @h.ActionDate.ToString("dd/MM HH:mm")
                                    </span>
                                </div>
                                <div class="text-muted" style="font-size:.75rem;">@h.ActionByName</div>
                                @if (!string.IsNullOrEmpty(h.Remark))
                                {
                                    <div class="text-danger" style="font-size:.75rem;">@h.Remark</div>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <style>
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .spin {
            display: inline-block;
            animation: spin 1s linear infinite;
        }
    </style>
    <script>
        // ── Lazy-fetch signature images ─────────────────────────────
        $(function () {
            // ดึง signature image สำหรับทุก .sig-lazy element
            $('.sig-lazy').each(function () {
                var $el  = $(this);
                var sam  = $el.data('sam');
                if (!sam) { $el.html(''); return; }

                $.ajax({
                    url: '/api/signature/image/' + encodeURIComponent(sam),
                    method: 'GET',
                    success: function (res) {
                        if (res && res.imageBase64) {
                            var img = $('<img>')
                                .attr('src', 'data:image/png;base64,' + res.imageBase64)
                                .attr('alt', 'Signature')
                                .css({ maxHeight: '42px', maxWidth: '100%', objectFit: 'contain' })
                                .addClass('mb-1');
                            $el.replaceWith(img);
                            // อัปเดต border สีเขียว
                            $el.closest('.border').addClass('border-success border-2');
                        } else {
                            $el.html('');
                        }
                    },
                    error: function () {
                        // ไม่มีลายเซ็น — ไม่แสดงอะไร
                        $el.html('');
                    }
                });
            });
        });
    </script>
}
