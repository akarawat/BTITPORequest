@model List<BTITPORequest.Models.UserRoleModel>
@{
    ViewData["Title"] = "Current Role Assignments";
    ViewData["BreadcrumbItems"] = new List<(string, string?)>
    {
        ("Dashboard", "/Dashboard"),
        ("Admin", "/Admin"),
        ("Roles", null)
    };
}
<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-list-check me-2 text-primary"></i>Role Assignments</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size:.85rem;">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>SAM Account</th>
                        <th>Department</th>
                        <th>Role</th>
                        <th>Assigned</th>
                        <th>By</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No roles assigned yet.</td></tr>
                    }
                    @foreach (var r in Model.OrderBy(x => x.RoleName).ThenBy(x => x.FullName))
                    {
                        var color = r.RoleName switch
                        {
                            "Issuer" => "info", "Approver" => "success",
                            "Admin" => "danger", _ => "secondary"
                        };
                        <tr>
                            <td class="fw-semibold">@r.FullName</td>
                            <td><code>@r.SamAcc</code></td>
                            <td>@r.Department</td>
                            <td><span class="badge bg-@color">@r.RoleName</span></td>
                            <td>@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-muted">@r.CreatedBy</td>
                            <td class="text-end">
                                <button class="btn btn-outline-danger btn-sm btn-remove-role-row"
                                        data-sam="@r.SamAcc"
                                        data-name="@r.FullName"
                                        data-role="@r.RoleName"
                                        title="Remove @r.RoleName from @r.FullName">
                                    <i class="bi bi-x-circle me-1"></i>Remove
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Toast feedback -->
<div id="roleToast" class="toast align-items-center border-0 position-fixed bottom-0 end-0 m-3"
     role="alert" style="z-index:9999;">
    <div class="d-flex">
        <div class="toast-body" id="roleToastBody"></div>
        <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-roles.js" asp-append-version="true"></script>
}
