<script>
function setLang(lang) {
  document.getElementById('content-th').style.display = lang === 'th' ? '' : 'none';
  document.getElementById('content-en').style.display = lang === 'en' ? '' : 'none';
  document.getElementById('btn-th').classList.toggle('active', lang === 'th');
  document.getElementById('btn-en').classList.toggle('active', lang === 'en');
  try { localStorage.setItem('wi-lang', lang); } catch(e) {}
}
document.addEventListener('DOMContentLoaded', function() {
  try { var l = localStorage.getItem('wi-lang'); if (l === 'en') setLang('en'); } catch(e) {}
});
</script>
